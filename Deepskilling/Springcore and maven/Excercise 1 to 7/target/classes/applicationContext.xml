<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
               http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/aop
               http://www.springframework.org/schema/aop/spring-aop.xsd">

    <!-- ==============================================================
         Exercise 6: Enable Component Scanning for the base package.
         Spring will auto-detect @Service, @Repository, @Component, @Aspect.
         This picks up: BookService, BookRepository, LoggingAspect
         ============================================================== -->

    <context:component-scan base-package="com.rishbootdev.librarymanagementsystem"/>

    <!-- ==============================================================
         Exercise 3 & 6: Enable AspectJ Auto-Proxy support.
         Required for @Aspect-annotated classes (LoggingAspect) to work.
         ============================================================== -->
    <aop:aspectj-autoproxy/>

    <!-- ==============================================================
         Exercise 1 & 5: Explicit XML Bean Definitions
         These XML-defined beans demonstrate manual IoC configuration.
         (The component-scan beans above are the annotation-based ones.)
         ============================================================== -->

    <!-- BookRepository bean (XML-defined, for Ex 1, 2, 5, 7) -->

    <bean id="bookRepository" class="com.cognizant.librarymanagementsystem.repository.BookRepository"/>

    <!-- ==============================================================
         Exercise 2 & 5: BookService with SETTER INJECTION
         The <property> tag calls setBookRepository(bookRepository).
         ============================================================== -->
    <bean id="bookServiceSetter"
          class="com.cognizant.librarymanagementsystem.service.BookService">
        <!-- Setter injection: Spring calls setBookRepository() -->
        <property name="bookRepository" ref="bookRepository"/>
    </bean>

    <!-- ==============================================================
         Exercise 7: BookService with CONSTRUCTOR INJECTION
         The <constructor-arg> tag calls BookService(BookRepository).
         ============================================================== -->
    <bean id="bookServiceConstructor"
          class="com.cognizant.librarymanagementsystem.service.BookService">

        <!-- Constructor injection: Spring calls BookService(BookRepository) -->

        <constructor-arg ref="bookRepository"/>
    </bean>

</beans>
